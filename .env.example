# توکن ربات تلگرام (از @BotFather دریافت کنید)
BOT_TOKEN=your_bot_token_here

# آیدی عددی ادمین (از @userinfobot دریافت کنید)
ADMIN_ID=123456789

# اطلاعات کارت بانکی برای پرداخت
CARD_NUMBER=1234-5678-9012-3456
CARD_HOLDER_NAME=نام و نام خانوادگی

# تنظیمات PostgreSQL
POSTGRES_DB=telegram_shop
POSTGRES_USER=telegram_bot
POSTGRES_PASSWORD=changeme123
DB_HOST=postgres
DB_PORT=5432

# زمان انقضای سفارش (دقیقه)
ORDER_EXPIRE_TIME=30

# فعال‌سازی ایموجی‌های پریمیوم (true/false)
USE_PREMIUM_EMOJIS=true
